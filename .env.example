# Database (MySQL)
DATABASE_URL=mysql://root:password@127.0.0.1:3306/teamflow

# Auth (Auth.js / NextAuth v5)
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JIRA Configuration
NEXT_PUBLIC_JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_USER_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_FRONTEND_LABEL=Frontend

# Atlassian Teams API
JIRA_ORG_ID=your-atlassian-org-id
JIRA_TEAM_IDS=team-id-1,team-id-2
JIRA_CLOUD_ID=your-atlassian-cloud-id

# GitHub (deployment tracking)
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Sync
SYNC_SECRET=a-random-secret-for-external-sync-triggers

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
