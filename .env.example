# Database (MySQL)
DATABASE_URL=mysql://root:password@127.0.0.1:3306/teamflow

# Auth (Auth.js / NextAuth v5)
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JIRA Configuration
NEXT_PUBLIC_JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_USER_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_FRONTEND_LABEL=Frontend

# Atlassian Teams API
JIRA_ORG_ID=your-atlassian-org-id
JIRA_TEAM_IDS=team-id-1,team-id-2
JIRA_CLOUD_ID=your-atlassian-cloud-id

# GitHub (deployment tracking)
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Cloudflare R2 (Avatar Storage)
CLOUDFLARE_R2_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=teamflow
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.your-domain.com

# Sync
SYNC_SECRET=a-random-secret-for-external-sync-triggers

# Cronicle (external cron scheduler — used for server-side admin tools / future logs page)
CRONICLE_BASE_URL=your-cronicle-url-here
CRONICLE_API_KEY=your-cronicle-api-key-here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# SMTP (password reset emails)
SMTP_HOST=mx.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD="your-smtp-password"
EMAIL_FROM="TeamFlow <noreply@example.com>"
