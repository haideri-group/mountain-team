# TeamFlow staging environment — copied to /home/haider/teamflow-staging/.env
# DO NOT COMMIT the filled-in version. This file is the template only.

# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# ─── Database ────────────────────────────────────────────────────────────────
# Host = container name on the shared mysql-phpmyadmin_mysql-network.
# DB + user are created via the SQL in docs/STAGING_SETUP.md.
DATABASE_URL=mysql://teamflow_user:REPLACE_ME@mysql-server:3306/teamflow

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=REPLACE_ME
AUTH_URL=https://staging-haider-team.appz.cc

# Google OAuth — create a separate staging OAuth client in Google Cloud Console
# with authorized redirect URI https://staging-haider-team.appz.cc/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── JIRA ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_JIRA_BASE_URL=https://tilemountain.atlassian.net
JIRA_USER_EMAIL=
JIRA_API_TOKEN=
JIRA_CLOUD_ID=
JIRA_ORG_ID=
JIRA_TEAM_IDS=
JIRA_FRONTEND_LABEL=Frontend
JIRA_SYNC_ARCHIVE_AGE_DAYS=0

# ─── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# ─── Cloudflare R2 (avatar cache) ────────────────────────────────────────────
# Can point at the existing prod bucket for read, or create a staging bucket.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
CLOUDFLARE_R2_PUBLIC_URL=

# ─── Time Doctor ─────────────────────────────────────────────────────────────
TIMEDOCTOR_EMAIL=
TIMEDOCTOR_PASSWORD=

# ─── Secrets for cron + webhooks ─────────────────────────────────────────────
SYNC_SECRET=REPLACE_ME
CRON_SECRET=REPLACE_ME

# ─── Cronicle (optional) ─────────────────────────────────────────────────────
CRONICLE_API_KEY=
CRONICLE_TEAMFLOW_CATEGORY_ID=

# ─── Email (optional) ────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ─── Migration flags ─────────────────────────────────────────────────────────
# Set to "true" only for the deploy window that contains Migration M5 (dropping
# deprecated JIRA-specific columns). Default is unset → destructive migrations
# are refused by scripts/migrate-all.ts.
# ALLOW_DESTRUCTIVE_MIGRATIONS=
