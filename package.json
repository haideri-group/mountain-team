{
  "name": "mountain-team",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "type-check": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "db:migrate:plan": "tsx scripts/migrate-all.ts",
    "db:migrate:apply": "tsx scripts/migrate-all.ts --apply",
    "cache-avatars": "tsx scripts/cache-avatars.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@base-ui/react": "^1.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.96.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "ipaddr.js": "^2.3.0",
    "lucide-react": "^1.7.0",
    "mysql2": "^3.9.7",
    "next": "16.2.2",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.3.0",
    "nodemailer": "^8.0.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-is": "^19.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@esbuild/win32-x64": "^0.28.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "shadcn": "^4.1.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
